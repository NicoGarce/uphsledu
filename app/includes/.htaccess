# Prevent direct HTTP access to include files in this directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Always return 404 for any direct request in this folder
    RewriteRule ^.*$ - [R=404,L]
</IfModule>

# Also set robots header for direct requests
<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
