# Prevent directory browsing
Options -Indexes

# Deny access to sensitive files
<Files "*.log">
    Order allow,deny
    Deny from all
</Files>

<Files "*.sql">
    Order allow,deny
    Deny from all
</Files>

<Files "*.bak">
    Order allow,deny
    Deny from all
</Files>

# Deny access to config directory
<Directory "config">
    Order allow,deny
    Deny from all
</Directory>

# Deny access to includes directory
<Directory "includes">
    Order allow,deny
    Deny from all
</Directory>

# Deny access to admin directory
<Directory "admin">
    Order allow,deny
    Deny from all
</Directory>
